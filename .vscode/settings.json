{
	// --- Standard ---
	"C_Cpp.default.cppStandard": "c++23",
	// --- CMake ---
	"cmake.useCMakePresets": "always",
	"cmake.options.statusBarVisibility": "visible",
	"cmake.debugConfig": {
		"cwd": "${workspaceFolder}"
	},
	// --- Code Analysis ---
	"C_Cpp.codeAnalysis.clangTidy.enabled": true,
	"C_Cpp.codeAnalysis.clangTidy.path": "clang-tidy",
	"C_Cpp.codeAnalysis.clangTidy.buildPath": "${workspaceFolder}/build",
	"C_Cpp.codeAnalysis.runAutomatically": true,
	// --- Cppcheck Analysis ---
	"cppcheck.enabled": true,
	"cppcheck.executable": "cppcheck",
	"cppcheck.onsave": true,
	"cppcheck.args": [
		"--enable=all",
		"--inline-suppr",
		"--suppress=missingIncludeSystem",
		"--std=c++23",
		"--project=${workspaceFolder}/build/compile_commands.json"
	],
	// --- Formatting ---
	"editor.formatOnSave": true,
	"editor.insertSpaces": false,
	"editor.tabSize": 4,
	"editor.detectIndentation": false,
	"clang-format.style": "file",
