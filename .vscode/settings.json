{
  // ---- CMake ----
  // Presets (CMakePresets.json) own the build directory and cache variables,
  // so we deliberately do NOT set cmake.buildDirectory / configureSettings here.
  "cmake.useCMakePresets": "always",
  "cmake.options.statusBarVisibility": "visible",

  // ---- clangd: the C/C++ language server ----
  // Semantic behavior (index, diagnostics, inlay hints, clang-tidy) is configured
  // in .clangd. These are launcher/driver flags that can't live in project config
  // (e.g. --query-driver is rejected from .clangd for security).
  "clangd.arguments": [
    "--query-driver=**/clang*,**/clang-cl*,**/clang++*,**/g++*,**/gcc*,**/c++*",
    "--header-insertion=iwyu",
    "--header-insertion-decorators",
    "--completion-style=detailed",
    "--function-arg-placeholders=true",
    "--pch-storage=memory",
    "-j=4"
  ],
  "clangd.onConfigChanged": "restart",
  "clangd.checkUpdates": false,

  // Defer entirely to clangd; disable Microsoft's competing IntelliSense engine.
  "C_Cpp.intelliSenseEngine": "disabled",

  // ---- Editor: format with clangd, driven by .clang-format ----
  "[cpp]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "editor.formatOnSave": true
  },

  // ---- File associations ----
  "files.associations": {
    "*.h.in": "cpp"
  }
}
