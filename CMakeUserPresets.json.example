{
	"version": 4,
	"configurePresets": [
		{
			"name": "my-linux-base",
			"hidden": true,
			"cacheVariables": {
				"VCPKG_ROOT_PATH": "/opt/vcpkg"
			}
		},
		{
			"name": "my-win-base",
			"hidden": true,
			"cacheVariables": {
				"VCPKG_ROOT_PATH": "C:/vcpkg"
			}
		},
		{
			"name": "my-clang-linux-debug",
			"inherits": [
				"my-linux-base",
				"clang-linux-debug"
			]
		},
		{
			"name": "my-clang-linux-release",
			"inherits": [
				"my-linux-base",
				"clang-linux-release"
			]
		},
		{
			"name": "my-gcc-linux-debug",
			"inherits": [
				"my-linux-base",
				"gcc-linux-debug"
			]
		},
		{
			"name": "my-gcc-linux-release",
			"inherits": [
				"my-linux-base",
				"gcc-linux-release"
			]
		},
		{
			"name": "my-msvc-debug",
			"inherits": [
				"my-win-base",
				"msvc-debug"
			]
		},
		{
			"name": "my-msvc-release",
			"inherits": [
				"my-win-base",
				"msvc-release"
			]
		},
		{
			"name": "my-clang-cl-debug",
			"inherits": [
				"my-win-base",
				"clang-cl-debug"
			]
		},
		{
			"name": "my-clang-cl-release",
			"inherits": [
				"my-win-base",
				"clang-cl-release"
			]
		},
		{
			"name": "my-mingw-debug",
			"inherits": [
				"my-win-base",
				"mingw-debug"
			]
		},
		{
			"name": "my-mingw-release",
			"inherits": [
				"my-win-base",
				"mingw-release"
			]
		}
	],
	"buildPresets": [
		{
			"name": "my-clang-linux-debug",
			"inherits": "build-type-debug",
			"configurePreset": "my-clang-linux-debug"
		},
		{
			"name": "my-clang-linux-release",
			"inherits": "build-type-release",
			"configurePreset": "my-clang-linux-release"
		},
		{
			"name": "my-gcc-linux-debug",
			"inherits": "build-type-debug",
			"configurePreset": "my-gcc-linux-debug"
		},
		{
			"name": "my-gcc-linux-release",
			"inherits": "build-type-release",
			"configurePreset": "my-gcc-linux-release"
		},
		{
			"name": "my-msvc-debug",
			"inherits": "build-type-debug",
			"configurePreset": "my-msvc-debug"
		},
		{
			"name": "my-msvc-release",
			"inherits": "build-type-release",
			"configurePreset": "my-msvc-release"
		},
		{
			"name": "my-clang-cl-debug",
			"inherits": "build-type-debug",
			"configurePreset": "my-clang-cl-debug"
		},
		{
			"name": "my-clang-cl-release",
			"inherits": "build-type-release",
			"configurePreset": "my-clang-cl-release"
		},
		{
			"name": "my-mingw-debug",
			"inherits": "build-type-debug",
			"configurePreset": "my-mingw-debug"
		},
		{
			"name": "my-mingw-release",
			"inherits": "build-type-release",
			"configurePreset": "my-mingw-release"
		}
	],
	"testPresets": [
		{
			"name": "test-my-clang-linux-debug",
			"inherits": "base-test",
			"configurePreset": "my-clang-linux-debug"
		},
		{
			"name": "test-my-clang-linux-release",
			"inherits": "base-test",
			"configurePreset": "my-clang-linux-release"
		},
		{
			"name": "test-my-gcc-linux-debug",
			"inherits": "base-test",
			"configurePreset": "my-gcc-linux-debug"
		},
		{
			"name": "test-my-gcc-linux-release",
			"inherits": "base-test",
			"configurePreset": "my-gcc-linux-release"
		},
		{
			"name": "test-my-msvc-debug",
			"inherits": "base-test",
			"configurePreset": "my-msvc-debug"
		},
		{
			"name": "test-my-msvc-release",
			"inherits": "base-test",
			"configurePreset": "my-msvc-release"
		},
		{
			"name": "test-my-clang-cl-debug",
			"inherits": "base-test",
			"configurePreset": "my-clang-cl-debug"
		},
		{
			"name": "test-my-clang-cl-release",
			"inherits": "base-test",
			"configurePreset": "my-clang-cl-release"
		},
		{
			"name": "test-my-mingw-debug",
			"inherits": "base-test",
			"configurePreset": "my-mingw-debug"
		},
		{
			"name": "test-my-mingw-release",
			"inherits": "base-test",
			"configurePreset": "my-mingw-release"
		}
	]
}