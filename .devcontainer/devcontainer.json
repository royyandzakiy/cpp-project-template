{
  // Portability tier — use this ONLY if you don't have a WSL/Linux toolbox.
  // If you already have WSL2 Ubuntu, dismiss the "Reopen in Container" prompt and use
  // "Reopen in WSL" instead (lighter, shared across all your projects).
  "name": "cpp-project-template-clangd",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      // Mirrors .vscode/extensions.json so the container is clangd-first too.
      "extensions": [
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "vadimcn.vscode-lldb",
        "editorconfig.editorconfig"
      ]
    }
  },
  // Keep build/ on a container-local volume so it never collides with a build/ configured
  // from the host or WSL — CMake bakes absolute paths into its cache, so a shared build/ dir
  // (same preset name, different path) causes "CMakeCache directory is different" errors.
  // Bonus: a real Linux volume is far faster than a Windows bind mount for build I/O.
  "mounts": [
    "source=${localWorkspaceFolderBasename}-build,target=${containerWorkspaceFolder}/build,type=volume"
  ],
  // chown the fresh volume to the runtime user, then give it a Conan default profile.
  "postCreateCommand": "sudo chown vscode:vscode build || true; conan profile detect --force || true",
  "remoteUser": "vscode"
}
