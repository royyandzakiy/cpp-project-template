# local_options.cmake — gitignored, never committed.
#
# Machine-local overrides. CMakeLists.txt includes this BEFORE project_options.cmake, so
# (under policy CMP0077, NEW by default at cmake_minimum_required 3.28) these plain set()s
# win over the option() defaults. This is the "maximise dev quality" profile: everything
# that is a pure win is ON; mutually-exclusive build VARIANTS (sanitizers) and clean-build-
# only throughput knobs (PCH/unity) are left to the presets / commented out.

# =============================================================================
# Package manager
# =============================================================================
# Provider: vcpkg | conan | none. Conan works with ANY preset (switching needs a fresh
# build dir). Use "none" to manage deps yourself via system find_package().
set(PKG_MANAGER conan)
# clang-cl profiles are auto-selected; other compilers are auto-detected. Override only if needed:
# set(CONAN_HOST_PROFILE "/path/to/your.ini")
#
# vcpkg only — set if vcpkg isn't on PATH / a standard location (auto-detects PATH, /opt/vcpkg,
# C:/vcpkg, ~/vcpkg, ...):
# set(VCPKG_ROOT_PATH "C:/vcpkg")     # Windows
# set(VCPKG_ROOT_PATH "/opt/vcpkg")   # Linux / macOS

# =============================================================================
# Code quality — always on, catch problems early
# =============================================================================
set(ENABLE_STRICT_COMPILER ON)  # warnings become errors
set(ENABLE_CLANG_TIDY ON)       # tidy on first-party production code (no-op if clang-tidy absent)

# =============================================================================
# Build speed — pure wins, both no-op if the tool is missing
# =============================================================================
set(ENABLE_CCACHE ON)           # cache compiles across rebuilds
set(ENABLE_FAST_LINKER ON)      # mold / lld if present

# =============================================================================
# Build everything
# =============================================================================
set(BUILD_TESTING ON)
set(BUILD_EXAMPLES ON)
set(GENERATE_VERSION_HEADER ON) # regenerate include/<project>/version.h from version.txt

# =============================================================================
# Throughput / profiling — situational, off for the inner loop
# =============================================================================
# PCH speeds clean/full builds but can slow incremental; unity is incremental-hostile.
# Good for CI / big clean builds, not day-to-day editing:
# set(ENABLE_PCH ON)
# set(ENABLE_UNITY_BUILD ON)
# set(ENABLE_CLANG_BUILD_ANALYZER ON)  # -ftime-trace + build-time analysis (Clang only)
# set(ENABLE_TRACY ON)                 # enable only when actively profiling
# set(ENABLE_PERFETTO ON)
