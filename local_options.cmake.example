# local_options.cmake — gitignored, never committed
# Copy this file to local_options.cmake and uncomment what applies to your machine.
# Loaded automatically by CMakeLists.txt before anything else.
#
# Use this for any machine-specific paths or local overrides — package managers,
# compiler paths, or feature flags you want to change without touching tracked files.

# =============================================================================
# vcpkg
# =============================================================================
# Only needed if vcpkg is not in PATH or a standard location.
# Auto-detected from: PATH, /opt/vcpkg, C:/vcpkg, ~/vcpkg, and other common paths.

# set(VCPKG_ROOT_PATH "/opt/vcpkg")     # Linux / macOS
# set(VCPKG_ROOT_PATH "C:/vcpkg")       # Windows

# Pick the dependency provider without touching tracked files (vcpkg | conan | none):
# set(PKG_MANAGER vcpkg)
# set(PKG_MANAGER none)   # manage dependencies yourself (system / find_package only)

# =============================================================================
# Conan  (works with ANY preset; switching requires a fresh build dir)
# =============================================================================
# set(PKG_MANAGER conan)
# clang-cl profiles are auto-selected; other compilers are auto-detected.
# Override only if you need a custom one:
# set(CONAN_HOST_PROFILE "/path/to/your.ini")

# =============================================================================
# Feature flag overrides (see project_options.cmake for all available options)
# =============================================================================
# set(ENABLE_STRICT_COMPILER OFF)
# set(ENABLE_CLANG_TIDY ON)
# set(ENABLE_ASAN ON)
# set(ENABLE_CCACHE ON)
